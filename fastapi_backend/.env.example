DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/mydatabase
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5433/testdatabase

ACCESS_SECRET_KEY=replace-with-a-long-random-secret
RESET_PASSWORD_SECRET_KEY=replace-with-a-long-random-secret
VERIFICATION_SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_SECONDS=3600

FRONTEND_URL=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
ENVIRONMENT=development

HF_MODEL_REPO=akhyarrasyid/app-findit-face-spoofing-model
HF_MODEL_FILENAME=dinov3_vitl_fold_best.onnx
MODEL_LOCAL_PATH=models/dinov3_vitl_fold_best.onnx
MODEL_INPUT_SIZE=336
MODEL_MAX_UPLOAD_BYTES=5242880
MODEL_MOCK_ENABLED=false
CAMERA_REAL_MASK_CALIBRATION_ENABLED=true
CAMERA_REAL_MASK_BOOST=0.20
CAMERA_REAL_MASK_MAX_OTHER_SPOOF_SCORE=0.20
CAMERA_REAL_MASK_MIN_PAIR_SCORE=0.35

MAIL_SERVER=localhost
MAIL_PORT=1025
MAIL_FROM=no-reply@example.com
MAIL_FROM_NAME=App FindIT
